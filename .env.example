# Firebase (client-side — already in src/firebase.js, not needed here)
# These are public keys baked into the bundle, no VITE_ prefix needed for Firebase.

# Cloudflare Pages Function secrets — set via Cloudflare dashboard or:
#   wrangler pages secret put ANTHROPIC_API_KEY
#   wrangler pages secret put GMAIL_MCP_URL
#   wrangler pages secret put GMAIL_OAUTH_TOKEN

ANTHROPIC_API_KEY=sk-ant-...

# URL of your Gmail MCP server (must support the MCP protocol).
# Example: https://gmail.googleapis.com/mcp/v1
GMAIL_MCP_URL=https://your-gmail-mcp-server/mcp/v1

# OAuth 2.0 Bearer token with Gmail scope (gmail.compose or gmail.modify).
# Refresh this token when it expires (typically every 1 hour).
GMAIL_OAUTH_TOKEN=ya29...
