# Firebase (client-side — already in src/firebase.js, not needed here)
# These are public keys baked into the bundle, no VITE_ prefix needed for Firebase.

# Cloudflare Pages Function secrets — set via Cloudflare dashboard or:
#   wrangler pages secret put GMAIL_CLIENT_ID
#   wrangler pages secret put GMAIL_CLIENT_SECRET
#   wrangler pages secret put GMAIL_REFRESH_TOKEN

# Google OAuth2 credentials for Gmail API (create at console.cloud.google.com).
# 1. Create a project, enable Gmail API.
# 2. Create OAuth 2.0 credentials (Desktop app type).
# 3. Run the one-time auth flow to get a refresh token (use OAuth 2.0 Playground
#    or a small Node script). The refresh token never expires unless revoked.
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
